@page
@model LoginModel

@{
    ViewData["Title"] = "Portal Access";
}

<div class="row mt-5 justify-content-center">
    <div class="col-md-6 col-lg-5">
        
        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold">🔐 Portal Access</h2>
            <p class="text-muted">Log in to manage NIF Builders projects and fleet assets.</p>
        </div>

        <div class="card shadow-sm border-0" style="border-top: 5px solid #343a40;">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0 text-warning">🚧 Secure Login</h4>
            </div>

            <div class="card-body bg-light p-4">
                <section>
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-warning shadow-none" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="fw-bold text-secondary">✉️ Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-warning shadow-none" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="fw-bold text-secondary">🔑 Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="checkbox mb-4 ms-1">
                            <label asp-for="Input.RememberMe" class="form-label fw-bold text-dark">
                                <input class="form-check-input border-dark me-2" asp-for="Input.RememberMe" />
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <div>
                            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-dark border-warning border-2 fw-bold shadow-sm">
                                🔓 Log In
                            </button>
                        </div>
                    </form>
                </section>
            </div>
            
            <div class="card-footer bg-white border-0 p-4 text-center">
                <div class="d-flex flex-column gap-2">
                    <p class="mb-0">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none fw-bold text-secondary">Forgot your password?</a>
                    </p>
                    <p class="mb-0">
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold text-primary">Register as a new user</a>
                    </p>
                    <p class="mb-0">
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none fw-bold text-info">Resend email confirmation</a>
                    </p>
                </div>
            </div>
        </div>
        
        @* External login section kept commented out per your original file *@
        @* <div class="col-md-6 col-md-offset-2">
            <section> ... </section>
        </div> *@

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}