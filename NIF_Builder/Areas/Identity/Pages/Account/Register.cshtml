@page
@model RegisterModel
@{
    ViewData["Title"] = "Register Personnel";
}

<div class="row mt-5 justify-content-center">
    <div class="col-md-8 col-lg-6">
        
        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold">👷 Create Account</h2>
            <p class="text-muted">Register a new personnel profile for the NIF Builders portal.</p>
        </div>

        <div class="card shadow-sm border-0" style="border-top: 5px solid #ffc107;">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0 text-warning">📝 Registration Form</h4>
            </div>

            <div class="card-body bg-light p-4">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Name" class="form-control border-warning shadow-none" placeholder="name please.." />
                        <label asp-for="Input.Name" class="fw-bold text-secondary">👤 Full Name</label>
                        <span asp-validation-for="Input.Name" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.CellPhone" class="form-control border-warning shadow-none" placeholder="Cell Phone please.." />
                                <label asp-for="Input.CellPhone" class="fw-bold text-secondary">📱 Cell Phone</label>
                                <span asp-validation-for="Input.CellPhone" class="text-danger small fw-bold"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Country" class="form-control border-warning shadow-none" placeholder="Country please.." />
                                <label asp-for="Input.Country" class="fw-bold text-secondary">🌍 Country</label>
                                <span asp-validation-for="Input.Country" class="text-danger small fw-bold"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control border-warning shadow-none" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="fw-bold text-secondary">✉️ Email Address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small fw-bold"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control border-dark shadow-none" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.Password" class="fw-bold text-secondary">🔑 Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small fw-bold"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-4">
                                <input asp-for="Input.ConfirmPassword" class="form-control border-dark shadow-none" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.ConfirmPassword" class="fw-bold text-secondary">🔒 Confirm Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-bold"></span>
                            </div>
                        </div>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-warning fw-bold text-dark border-dark shadow-sm">
                        ✅ Register Personnel
                    </button>
                </form>
            </div>
        </div>

        @* External login section kept commented out per your original file *@
        @* <div class="mt-4">
            <section>
                <h3>Use another service to register.</h3>
                ...
            </section>
        </div> *@
        
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}