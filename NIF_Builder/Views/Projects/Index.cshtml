@model IEnumerable<NIF_Builder.Models.Project>
@{
    ViewData["Title"] = "Project List";
}

<div class="row mt-4">
    <div class="col-12">
        <div class="text-center mb-4">
            <h2 class="display-4 fw-bold">🏗️ Active Projects</h2>
            <p class="text-muted">Master dashboard for all current and completed job sites.</p>
        </div>
        
        <div class="d-flex justify-content-end mb-4">
            <a asp-action="Create" asp-controller="Projects" class="btn btn-warning fw-bold text-dark border-dark shadow-sm">
                ➕ Add New Project
            </a>
        </div>
        
        @foreach (var p in Model)
        {
            <div class="card mb-4 shadow-sm border-0" style="border-top: 5px solid #ffc107;">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <div class="d-flex align-items-center flex-wrap gap-4">
                        @if (!string.IsNullOrEmpty(p.ProjectDocuments))
                        {
                            <img src="@p.ProjectDocuments" width="40" height="40" style="border-radius:5px; object-fit: cover; border: 1px solid #ccc;" alt="Doc" title="Site Document Attached" />
                        }
                        else
                        {
                            <div style="width: 40px; height: 40px; border-radius: 5px; background-color: #e9ecef; border: 1px dashed #ccc; display:flex; justify-content:center; align-items:center;" title="No Document">
                                📄
                            </div>
                        }
                        <span class="fs-4 fw-bold text-warning">@Html.DisplayFor(xx => p.ProjectName)</span>
                        <span class="badge bg-secondary border border-light text-light px-3 py-2 fs-6">
                            💲 $@Html.DisplayFor(xx => p.Budget)
                        </span>
                        <span class="text-light">
                            <i class="fw-bold text-warning">Start:</i> @p.StartDate.ToString("MMM dd, yyyy")
                        </span>
                        <span class="text-light">
                            <i class="fw-bold text-warning">Est. End:</i> @p.EstimateEndDate.ToString("MMM dd, yyyy")
                        </span>
                        <span>
                            @(p.WorkInProgress? Html.Raw("<span class='badge bg-warning text-dark px-3 py-2'>⏳ In Progress</span>") : Html.Raw("<span class='badge bg-success px-3 py-2'>✅ Completed</span>"))
                        </span>
                    </div>
                    <div>
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-controller="Projects" asp-route-id="@p.ProjectID" class="btn btn-outline-light btn-sm fw-bold">✏️ Edit</a>
                            <a asp-action="Delete" asp-controller="Projects" asp-route-id="@p.ProjectID" class="btn btn-outline-danger btn-sm fw-bold">❌ Delete</a>
                        </div>
                    </div>
                </div>
                
                <div class="card-body bg-light p-4">
                    <h6 class="text-dark fw-bold border-bottom border-warning pb-2 mb-3">🚜 Deployed Machinery Overview</h6>
                    
                    @if (p.ProjectEquipments != null && p.ProjectEquipments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover bg-white mb-0 shadow-sm align-middle">
                                <thead class="table-dark text-warning">
                                    <tr>
                                        <th class="ps-3">Asset Name / Model</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in p.ProjectEquipments)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold text-secondary">
                                                <span class="text-dark">@Html.DisplayFor(xx => item.Equipment.EquipmentName)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info border-info text-dark py-3 mb-0 shadow-sm">
                            <strong>No Assets Deployed:</strong> There is currently no machinery allocated to this site.
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>