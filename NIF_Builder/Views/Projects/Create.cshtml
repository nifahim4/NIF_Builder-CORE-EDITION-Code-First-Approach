@model NIF_Builder.Models.ViewModels.ProjectVM
@{
    ViewData["Title"] = "Create Project";
}

<div class="row mt-4">
    <div class="col">
        <div id="panel"></div>
        <form id="frmCreate"
              asp-action="Create"
              asp-controller="Projects"
              data-ajax-method="post"
              data-ajax-mode="replace"
              data-ajax-update="#panel"
              data-ajax-success="success"
              data-ajax="true"
              enctype="multipart/form-data">
            <div class="d-flex justify-content-between">
                <div class="col-6">
                    <h1 class="display-5">Add New Project</h1>
                    
                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="ProjectName"></label>
                        <div class="col-7">
                            <input asp-for="ProjectName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="ProjectName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="StartDate"></label>
                        <div class="col-7">
                            <input asp-for="StartDate" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="EstimateEndDate"></label>
                        <div class="col-7">
                            <input asp-for="EstimateEndDate" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="EstimateEndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="Budget"></label>
                        <div class="col-7">
                            <input asp-for="Budget" class="form-control form-control-sm" type="number" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="Budget" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="ProjectDocumentFile"></label>
                        <div class="col-7">
                            <input asp-for="ProjectDocumentFile" class="form-control form-control-sm" type="file" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="ProjectDocumentFile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-form-label col-form-label-sm col-3" asp-for="WorkInProgress"></label>
                        <div class="col-7">
                            <input asp-for="WorkInProgress" type="checkbox" />
                        </div>
                        <div class="col-2">
                            <span asp-validation-for="WorkInProgress" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-2 mt-4">
                        <div class="col-10 offset-3">
                            <input type="submit" value="Save Project" class="btn btn-primary" />
                        </div>
                    </div>
                </div>

                <div class="col-5">
                    <h1 class="display-5">Equipment Fleet</h1>
                    <div class="d-flex justify-content-end">
                        <a class="btn btn-outline-primary btn-sm mb-1" id="btnPlus">+ Add Row</a>
                    </div>
                    <div id="equipmentContainer">
                        <script>
                                                    LoadData();
                        </script>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>
    <script src="~/lib/ajax/dist/jquery.unobtrusive-ajax.js"></script>

    <script>
        function success() {
            $("#frmCreate").trigger('reset');
            $("#equipmentContainer").empty();
            LoadData();
        }

        function LoadData() {
            $.ajax({
                url: "/Projects/AddNewEquipment",
                type: "GET",
                success: function (data) {
                    $("#equipmentContainer").append(data);
                }
            });
        }
    </script>
}