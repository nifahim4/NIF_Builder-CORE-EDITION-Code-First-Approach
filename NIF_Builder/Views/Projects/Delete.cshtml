@model NIF_Builder.Models.Project

@{
    ViewData["Title"] = "Delete Project";
}

<div class="row mt-4 justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold text-danger">🗑️ Delete Project</h2>
            <p class="text-muted">Remove an active construction site and its assignments from the database.</p>
        </div>

        <div class="card shadow-sm border-0" style="border-top: 5px solid #dc3545;">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0 text-warning">⚠️ Confirm Deletion</h4>
            </div>

            <div class="card-body bg-light p-4">
                <div class="alert alert-danger shadow-sm border-danger text-center mb-4">
                    <h5 class="mb-1 fw-bold">Are you sure you want to delete this project?</h5>
                    <small>This action cannot be undone and will unassign all machinery currently deployed to this site.</small>
                </div>

                <div class="mb-4 p-3 bg-white border rounded shadow-sm text-center">
                    <span class="text-muted fw-bold d-block mb-2 text-uppercase" style="letter-spacing: 1px;">Project Name</span>
                    <span class="fs-4 fw-bold text-dark">🏗️ @Html.DisplayFor(model => model.ProjectName)</span>
                </div>

                <hr class="text-secondary mb-4" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ProjectID" />
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4">
                            ⬅️ Cancel
                        </a>
                        <button type="submit" class="btn btn-danger fw-bold px-4 shadow-sm">
                            🗑️ Delete Project
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>