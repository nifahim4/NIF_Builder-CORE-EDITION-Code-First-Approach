@model NIF_Builder.Models.ViewModels.ProjectVM
@{
    ViewData["Title"] = "Edit Project";
}

<div class="row mt-4 justify-content-center">
    <div class="col-12">
        <div class="text-center mb-4">
            <h2 class="display-5 fw-bold">✏️ Edit Project</h2>
            <p class="text-muted">Update details and modify equipment allocation for this job site.</p>
        </div>
        
        <div id="panel"></div>
        
        <form id="frmEdit"
              asp-action="Edit"
              asp-controller="Projects"
              data-ajax-method="post"
              data-ajax-mode="replace"
              data-ajax-update="#panel"
              data-ajax-success="success"
              data-ajax="true"
              enctype="multipart/form-data">
            
            <input type="hidden" asp-for="ProjectID" />
            <input type="hidden" asp-for="ProjectDocuments" />

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="card shadow-sm border-0 h-100" style="border-top: 5px solid #ffc107;">
                        <div class="card-header bg-dark text-white py-3">
                            <h4 class="mb-0">🏗️ Project Details</h4>
                        </div>
                        <div class="card-body bg-light p-4">
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" asp-for="ProjectName"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-warning text-dark border-warning">🏷️</span>
                                    <input asp-for="ProjectName" class="form-control border-warning shadow-none" />
                                </div>
                                <span asp-validation-for="ProjectName" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark" asp-for="StartDate"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-warning text-dark border-warning">📅</span>
                                        <input asp-for="StartDate" class="form-control border-warning shadow-none" type="date" />
                                    </div>
                                    <span asp-validation-for="StartDate" class="text-danger small mt-1 d-block fw-bold"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark" asp-for="EstimateEndDate"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-warning text-dark border-warning">🏁</span>
                                        <input asp-for="EstimateEndDate" class="form-control border-warning shadow-none" type="date" />
                                    </div>
                                    <span asp-validation-for="EstimateEndDate" class="text-danger small mt-1 d-block fw-bold"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" asp-for="Budget"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-warning text-dark border-warning">💲</span>
                                    <input asp-for="Budget" class="form-control border-warning shadow-none" type="number" />
                                </div>
                                <span asp-validation-for="Budget" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark" asp-for="ProjectDocumentFile"></label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-warning text-dark border-warning">📄</span>
                                    <input asp-for="ProjectDocumentFile" class="form-control border-warning shadow-none" type="file" />
                                </div>
                                @if (!string.IsNullOrEmpty(Model.ProjectDocuments))
                                {
                                    <a href="@Model.ProjectDocuments" target="_blank" class="badge bg-dark text-warning border border-warning text-decoration-none px-3 py-2">
                                        🔍 View Current Blueprint/Document
                                    </a>
                                }
                                <span asp-validation-for="ProjectDocumentFile" class="text-danger small mt-1 d-block fw-bold"></span>
                            </div>

                            <div class="mb-4 form-check form-switch mt-3 fs-5">
                                <input asp-for="WorkInProgress" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" />
                                <label class="form-check-label fw-bold text-dark ms-2" for="flexSwitchCheckDefault">Active Work In Progress</label>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="card shadow-sm border-0 h-100" style="border-top: 5px solid #343a40;">
                        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">🚜 Equipment Fleet</h4>
                            <a class="btn btn-warning btn-sm fw-bold text-dark" id="btnPlus">➕ Add Asset</a>
                        </div>
                        <div class="card-body bg-light p-4">
                            <div class="alert alert-secondary py-2 border-secondary small text-center mb-4">
                                Update machinery allocation for this project.
                            </div>
                            
                            <div id="equipmentContainer">
                                @foreach (var item in Model.EquipmentList)
                                {
                                    <script>
                                                                        LoadData(@item);
                                    </script>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white p-4 border-0 text-end">
                            <a asp-action="Index" class="btn btn-outline-secondary fw-bold me-2">⬅️ Cancel</a>
                            <button type="submit" class="btn btn-dark border-warning border-2 fw-bold px-4">💾 Update Project</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>
    <script src="~/lib/ajax/dist/jquery.unobtrusive-ajax.js"></script>

    <script>
        function success() {
            alert("Project Updated Successfully!");
        }

        function LoadData(id = null) {
            var url = "/Projects/AddNewEquipment";
            if (id != null) {
                url += "/" + id;
            }
            $.ajax({
                url: url,
                type: "GET",
                success: function (data) {
                    $("#equipmentContainer").append(data);
                }
            });
        }
    </script>
}